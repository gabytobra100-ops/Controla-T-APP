<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/txtTituloAgregarPedido"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Agregar Pedido"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cliente"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spClientesPedido"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Producto"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spProductosPedido"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Estado"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spEstadoPedido"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cantidad"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etCantidadPedido"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Ingresa la cantidad"
            android:inputType="number"
            android:textColor="#FFFFFF"
            android:textColorHint="#B0BEC5"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fecha de entrega"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etFechaEntregaPedido"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Ej. 20/04/2026"
            android:inputType="text"
            android:textColor="#FFFFFF"
            android:textColorHint="#B0BEC5"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnGuardarPedido"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Guardar pedido"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#1B263B"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>