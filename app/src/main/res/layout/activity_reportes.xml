<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- TÍTULO -->
        <TextView
            android:id="@+id/txtTituloReportes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reportes"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp" />

        <!-- TARJETA PRODUCTOS -->
        <TextView
            android:id="@+id/txtTotalProductos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Total de productos: 0"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="#1B263B"
            android:padding="16dp"
            android:layout_marginBottom="12dp" />

        <!-- TARJETA VENTAS -->
        <TextView
            android:id="@+id/txtTotalVentas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Total de ventas: 0"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="#1B263B"
            android:padding="16dp"
            android:layout_marginBottom="12dp" />

        <!-- TARJETA INGRESOS -->
        <TextView
            android:id="@+id/txtIngresosTotales"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ingresos totales: $0.0"
            android:textColor="#4CAF50"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="#1B263B"
            android:padding="16dp"
            android:layout_marginBottom="12dp" />

        <!-- TARJETA STOCK -->
        <TextView
            android:id="@+id/txtProductosSinStock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Productos sin stock: 0"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="#1B263B"
            android:padding="16dp"
            android:layout_marginBottom="12dp" />

    </LinearLayout>
</ScrollView>