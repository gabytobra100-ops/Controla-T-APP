<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A"
    android:padding="16dp">

    <TextView
        android:id="@+id/Titulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Controla-T"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="180dp" />

    <TextView
        android:id="@+id/Subtitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sistema de gestión de negocios"
        android:textColor="#B0BEC5"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/Titulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/btnAdministrador"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="Administrador"
        android:backgroundTint="#1B263B"
        android:textColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/Subtitulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="48dp" />

    <Button
        android:id="@+id/btnPersonal"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:backgroundTint="#1B263B"
        android:textColor="#FFFFFF"
        android:text="Personal"
        app:layout_constraintTop_toBottomOf="@id/btnAdministrador"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp" />

</androidx.constraintlayout.widget.ConstraintLayout>