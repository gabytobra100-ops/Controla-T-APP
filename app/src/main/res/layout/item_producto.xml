<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#1B263B">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- IMAGEN -->
        <ImageView
            android:id="@+id/imgProducto"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:scaleType="centerCrop"
            android:src="@drawable/fragancias" />

        <!-- INFO -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <!-- NOMBRE -->
            <TextView
                android:id="@+id/txtNombreProducto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Perfume"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- DESCRIPCIÓN -->
            <TextView
                android:id="@+id/txtDescripcionProducto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fragancia: "
                android:textColor="#B0BEC5"
                android:textSize="14sp"
                android:layout_marginTop="6dp" />

            <!-- PRECIO -->
            <TextView
                android:id="@+id/txtPrecioProducto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Precio: $100"
                android:textColor="#00FF66"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="6dp" />

            <!-- STOCK -->
            <TextView
                android:id="@+id/txtStockProducto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stock: 10"
                android:textColor="#B0BEC5"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />

            <!-- ID -->
            <TextView
                android:id="@+id/txtIdProducto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ID: 1"
                android:textColor="#FF9800"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>