<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#0D1B2A">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarAdmin"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#1B263B"
            android:title="Controla-T CRM"
            android:titleTextColor="#FFFFFF"
            app:navigationIconTint="#FFFFFF" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/txtTituloDashboard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dashboard"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Resumen ejecutivo del negocio"
                    android:textColor="#B0BEC5"
                    android:textSize="15sp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="20dp" />

                <!-- CARD INGRESOS -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardIngresosDashboard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="#1B263B">

                    <LinearLayout
                        android:id="@+id/layoutIngresosDashboard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:padding="20dp"
                        android:background="?attr/selectableItemBackground">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ingresos totales"
                            android:textColor="#B0BEC5"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="12dp">

                            <TextView
                                android:id="@+id/btnPeriodoDiario"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Diario"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="6dp"
                                android:background="@drawable/bg_periodo_activo" />

                            <TextView
                                android:id="@+id/btnPeriodoSemanal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Semanal"
                                android:textColor="#B0BEC5"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="6dp"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_periodo_inactivo" />

                            <TextView
                                android:id="@+id/btnPeriodoMensual"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mensual"
                                android:textColor="#B0BEC5"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="6dp"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_periodo_inactivo" />
                        </LinearLayout>

                        <FrameLayout
                            android:id="@+id/frameCirculoIngresos"
                            android:layout_width="220dp"
                            android:layout_height="220dp"
                            android:layout_marginTop="16dp"
                            android:background="@drawable/bg_circle_dashboard">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/txtTituloPeriodo"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Balance mensual"
                                    android:textColor="#B0BEC5"
                                    android:textSize="14sp" />

                                <TextView
                                    android:id="@+id/txtDashboardIngresos"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="$0.00"
                                    android:textColor="#FFFFFF"
                                    android:textSize="30sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/txtPorcentajeMeta"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:text="0% de la meta"
                                    android:textColor="#B0BEC5"
                                    android:textSize="13sp" />

                                <TextView
                                    android:id="@+id/txtEstadoMeta"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="Sin meta definida"
                                    android:textColor="#FFFFFF"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="20dp"
                            android:gravity="center"
                            android:weightSum="3">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Diario"
                                    android:textColor="#B0BEC5"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/txtPorcentajeDiario"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0%"
                                    android:textColor="#29B6F6"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Semanal"
                                    android:textColor="#B0BEC5"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/txtPorcentajeSemanal"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0%"
                                    android:textColor="#7E57C2"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Mensual"
                                    android:textColor="#B0BEC5"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/txtPorcentajeMensual"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0%"
                                    android:textColor="#4CAF50"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- FILA RESUMEN 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardClientesDashboard"
                        android:layout_width="0dp"
                        android:layout_height="110dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="16dp"
                        app:cardBackgroundColor="#1B263B">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Clientes"
                                android:textColor="#B0BEC5"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/txtDashboardClientes"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#FFFFFF"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardVentasDashboard"
                        android:layout_width="0dp"
                        android:layout_height="110dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        app:cardCornerRadius="16dp"
                        app:cardBackgroundColor="#1B263B">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ventas"
                                android:textColor="#B0BEC5"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/txtDashboardVentas"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#FFFFFF"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- FILA RESUMEN 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="14dp">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardProductosDashboard"
                        android:layout_width="0dp"
                        android:layout_height="110dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="16dp"
                        app:cardBackgroundColor="#1B263B">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Productos"
                                android:textColor="#B0BEC5"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/txtDashboardProductos"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#FFFFFF"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardSinStockDashboard"
                        android:layout_width="0dp"
                        android:layout_height="110dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        app:cardCornerRadius="16dp"
                        app:cardBackgroundColor="#1B263B">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sin stock"
                                android:textColor="#B0BEC5"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/txtDashboardSinStock"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#F44336"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- CARD GRÁFICA COMPARATIVA -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="#1B263B">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Comparativa general"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Relación entre ventas, clientes y productos"
                            android:textColor="#B0BEC5"
                            android:textSize="13sp"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="18dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="180dp"
                            android:orientation="horizontal"
                            android:gravity="bottom"
                            android:weightSum="3">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="bottom|center_horizontal">

                                <TextView
                                    android:id="@+id/txtGraficaVentasValor"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="#FFFFFF"
                                    android:textSize="13sp"
                                    android:layout_marginBottom="6dp" />

                                <FrameLayout
                                    android:layout_width="28dp"
                                    android:layout_height="120dp"
                                    android:background="#263238">

                                    <View
                                        android:id="@+id/barVentas"
                                        android:layout_width="match_parent"
                                        android:layout_height="10dp"
                                        android:layout_gravity="bottom"
                                        android:background="#4CAF50" />
                                </FrameLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Ventas"
                                    android:textColor="#B0BEC5"
                                    android:textSize="13sp"
                                    android:layout_marginTop="8dp" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="bottom|center_horizontal">

                                <TextView
                                    android:id="@+id/txtGraficaClientesValor"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="#FFFFFF"
                                    android:textSize="13sp"
                                    android:layout_marginBottom="6dp" />

                                <FrameLayout
                                    android:layout_width="28dp"
                                    android:layout_height="120dp"
                                    android:background="#263238">

                                    <View
                                        android:id="@+id/barClientes"
                                        android:layout_width="match_parent"
                                        android:layout_height="10dp"
                                        android:layout_gravity="bottom"
                                        android:background="#29B6F6" />
                                </FrameLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Clientes"
                                    android:textColor="#B0BEC5"
                                    android:textSize="13sp"
                                    android:layout_marginTop="8dp" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="bottom|center_horizontal">

                                <TextView
                                    android:id="@+id/txtGraficaProductosValor"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="#FFFFFF"
                                    android:textSize="13sp"
                                    android:layout_marginBottom="6dp" />

                                <FrameLayout
                                    android:layout_width="28dp"
                                    android:layout_height="120dp"
                                    android:background="#263238">

                                    <View
                                        android:id="@+id/barProductos"
                                        android:layout_width="match_parent"
                                        android:layout_height="10dp"
                                        android:layout_gravity="bottom"
                                        android:background="#7E57C2" />
                                </FrameLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Productos"
                                    android:textColor="#B0BEC5"
                                    android:textSize="13sp"
                                    android:layout_marginTop="8dp" />
                            </LinearLayout>

                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- CARD RANKING COMERCIAL -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardRankingComercial"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="#1B263B">

                    <LinearLayout
                        android:id="@+id/layoutRankingComercial"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ranking comercial"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Consulta top clientes, fragancias o días"
                            android:textColor="#B0BEC5"
                            android:textSize="13sp"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="14dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="16dp">

                            <TextView
                                android:id="@+id/btnRankingClientes"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Clientes"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="6dp"
                                android:background="@drawable/bg_periodo_activo" />

                            <TextView
                                android:id="@+id/btnRankingFragancias"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Fragancias"
                                android:textColor="#B0BEC5"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="6dp"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_periodo_inactivo" />

                            <TextView
                                android:id="@+id/btnRankingDias"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Días"
                                android:textColor="#B0BEC5"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="6dp"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_periodo_inactivo" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/txtRanking1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1. Sin datos"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:layout_marginBottom="10dp" />

                        <TextView
                            android:id="@+id/txtRanking2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2. Sin datos"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:layout_marginBottom="10dp" />

                        <TextView
                            android:id="@+id/txtRanking3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3. Sin datos"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:layout_marginBottom="10dp" />

                        <TextView
                            android:id="@+id/txtRanking4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="4. Sin datos"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:layout_marginBottom="10dp" />

                        <TextView
                            android:id="@+id/txtRanking5"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5. Sin datos"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- CARD ALERTAS -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardAlertas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:layout_marginBottom="24dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="#1B263B">

                    <LinearLayout
                        android:id="@+id/layoutAlertas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp"
                        android:background="?attr/selectableItemBackground">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Alertas del negocio"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Recordatorios y notificaciones importantes"
                            android:textColor="#B0BEC5"
                            android:textSize="13sp"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:id="@+id/txtAlerta1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="• Sin alertas"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:layout_marginBottom="10dp" />

                        <TextView
                            android:id="@+id/txtAlerta2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="• Sin alertas"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:layout_marginBottom="10dp" />

                        <TextView
                            android:id="@+id/txtAlerta3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="• Sin alertas"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        android:background="#1B263B"
        app:itemTextColor="#FFFFFF"
        app:itemIconTint="#FFFFFF"
        app:menu="@menu/menu_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>