<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#1B263B">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- CLIENTE (TÍTULO) -->
        <TextView
            android:id="@+id/txtPedidoCliente"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cliente"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- PRODUCTO -->
        <TextView
            android:id="@+id/txtPedidoProducto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Producto: "
            android:textColor="#B0BEC5"
            android:textSize="14sp"
            android:layout_marginTop="6dp" />

        <!-- CANTIDAD -->
        <TextView
            android:id="@+id/txtPedidoCantidad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cantidad: "
            android:textColor="#00FF66"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />

        <!-- FECHA -->
        <TextView
            android:id="@+id/txtPedidoFecha"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fecha: "
            android:textColor="#B0BEC5"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />

        <!-- ESTADO -->
        <TextView
            android:id="@+id/txtPedidoEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pendiente"
            android:textColor="#FF9800"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginTop="6dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>