<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Registrar Pedido"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Guarda pedidos pendientes de tus clientes"
            android:textColor="#B0BEC5"
            android:textSize="15sp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="20dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="18dp"
            app:cardBackgroundColor="#1B263B"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cliente"
                    android:textColor="#B0BEC5"
                    android:textSize="13sp" />

                <Spinner
                    android:id="@+id/spClientePedido"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Producto"
                    android:textColor="#B0BEC5"
                    android:textSize="13sp"
                    android:layout_marginTop="14dp" />

                <Spinner
                    android:id="@+id/spProductoPedido"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cantidad"
                    android:textColor="#B0BEC5"
                    android:textSize="13sp"
                    android:layout_marginTop="14dp" />

                <EditText
                    android:id="@+id/etCantidadPedido"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Cantidad"
                    android:inputType="number"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#B0BEC5"
                    android:backgroundTint="#B0BEC5"
                    android:padding="12dp"
                    android:layout_marginTop="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fecha de entrega"
                    android:textColor="#B0BEC5"
                    android:textSize="13sp"
                    android:layout_marginTop="14dp" />

                <EditText
                    android:id="@+id/etFechaEntregaPedido"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Selecciona una fecha"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#B0BEC5"
                    android:backgroundTint="#B0BEC5"
                    android:padding="12dp"
                    android:layout_marginTop="6dp" />

                <Button
                    android:id="@+id/btnGuardarPedido"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Guardar Pedido"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:backgroundTint="#0D1B2A"
                    android:layout_marginTop="22dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>