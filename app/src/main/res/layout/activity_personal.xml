<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <!-- TÍTULO -->
    <TextView
        android:id="@+id/txtTituloPersonal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Panel de Empleado"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"/>

    <!-- BOTÓN VENTAS -->
    <Button
        android:id="@+id/btnRegistrarVenta"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Registrar Venta"
        app:layout_constraintTop_toBottomOf="@id/txtTituloPersonal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp"/>

    <!-- BOTÓN PRODUCTOS -->
    <Button
        android:id="@+id/btnVerProductos"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Consultar Productos"
        app:layout_constraintTop_toBottomOf="@id/btnRegistrarVenta"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>